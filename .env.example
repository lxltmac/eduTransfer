# GEMINI_API_KEY: Required for Gemini AI API calls
GEMINI_API_KEY="your_gemini_api_key"

# Database Configuration
# SQLite (default - local development)
# DB_PATH=/path/to/edu_transfer.db
# DATA_DIR=/path/to/data

# PostgreSQL (production on Render/Vercel)
# Requires async refactor of all database operations
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Render Deployment
# 1. Free tier: Use SQLite, data persists until next deploy (not recommended)
# 2. Paid: Enable Persistent Disk, set DATA_DIR=/app/data
# 3. PostgreSQL: Use Neon/Supabase, set DATABASE_URL

# Uploads Directory
UPLOAD_DIR=/tmp/uploads
